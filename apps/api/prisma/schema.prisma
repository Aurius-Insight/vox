generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // URLs (url + directUrl) ficam em `prisma.config.ts` — Prisma 7 nao
  // aceita mais essas chaves dentro do schema.
}

enum Role {
  diretor
  coordenacao
  professor
}

enum LeadStageKind {
  active
  won
  lost
}

model LeadStage {
  id         String        @id @default(cuid())
  slug       String        @unique
  label      String
  color      String?
  order      Int           @unique
  kind       LeadStageKind @default(active)
  systemic   Boolean       @default(false)
  archived   Boolean       @default(false)
  archivedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  leads      Lead[]
}

enum AttendanceStatus {
  presente
  no_show
}

enum StudentType {
  experimental
  matriculado
}

model Subject {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teachers      User[]
  classSessions ClassSession[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  roles        Role[]
  active       Boolean  @default(true)
  subjectId    String?
  unitId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subject            Subject?       @relation(fields: [subjectId], references: [id])
  unit               Unit?          @relation(fields: [unitId], references: [id])
  taughtClasses      ClassSession[] @relation("TeacherClasses")
  markedAttendances  Attendance[]   @relation("MarkedAttendances")

  @@index([subjectId])
  @@index([unitId])
}

model Lead {
  id                    String    @id @default(cuid())
  name                  String
  whatsapp              String?
  email                 String?
  unitInterest          String
  campaign              String?
  source                String
  stageId               String
  responsibleUserId     String?
  botconversaContactId  String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  stage                 LeadStage      @relation(fields: [stageId], references: [id])
  bookings              ClassBooking[]
  student               Student?

  @@index([whatsapp])
  @@index([stageId])
  @@index([campaign])
}

model Student {
  id             String   @id @default(cuid())
  contactId      String?
  leadId         String?  @unique
  unitId         String?
  name           String
  whatsapp       String?
  email          String?
  cpfHash        String?
  cpfMasked      String?
  enrollmentCode String      @unique
  type           StudentType @default(matriculado)
  packageName    String?
  creditBalance  Int         @default(0)
  tags           String[]    @default([])
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lead           Lead?          @relation(fields: [leadId], references: [id])
  unit           Unit?          @relation(fields: [unitId], references: [id])
  bookings       ClassBooking[]
  attendances    Attendance[]

  @@index([whatsapp])
  @@index([cpfHash])
  @@index([unitId])
}

model ClassSession {
  id            String    @id @default(cuid())
  subjectId     String?
  unitId        String?
  isGuest       Boolean   @default(false)
  teacherUserId String?
  startsAt      DateTime
  endsAt        DateTime
  capacity      Int
  canceledAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subject       Subject?       @relation(fields: [subjectId], references: [id])
  unit          Unit?          @relation(fields: [unitId], references: [id])
  teacher       User?          @relation("TeacherClasses", fields: [teacherUserId], references: [id])
  bookings      ClassBooking[]
  attendances   Attendance[]

  @@index([unitId])
  @@index([startsAt])
  @@index([teacherUserId])
  @@index([subjectId])
}

enum BookingType {
  regular
  experimental
}

enum BookingStatus {
  agendado
  cancelado
}

model ClassBooking {
  id             String        @id @default(cuid())
  classSessionId String
  studentId      String?
  leadId         String?
  type           BookingType
  status         BookingStatus @default(agendado)
  consumesCredit Boolean       @default(true)
  createdAt      DateTime      @default(now())
  canceledAt     DateTime?

  classSession   ClassSession  @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  student        Student?      @relation(fields: [studentId], references: [id])
  lead           Lead?         @relation(fields: [leadId], references: [id])

  @@unique([classSessionId, studentId])
  @@unique([classSessionId, leadId])
  @@index([classSessionId])
  @@index([studentId])
  @@index([leadId])
}

model Attendance {
  id             String           @id @default(cuid())
  classSessionId String
  studentId      String
  status         AttendanceStatus
  creditConsumed Boolean          @default(false)
  markedByUserId String
  markedAt       DateTime         @default(now())

  classSession    ClassSession     @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  student         Student          @relation(fields: [studentId], references: [id])
  markedBy        User             @relation("MarkedAttendances", fields: [markedByUserId], references: [id])

  @@unique([classSessionId, studentId])
  @@index([classSessionId])
  @@index([studentId])
  @@index([markedByUserId])
}

model IntegrationEvent {
  id              String   @id @default(cuid())
  source          String
  externalEventId String   @unique
  payload         Json
  processedAt     DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorType   String
  entityType  String
  entityId    String
  action      String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
}

model Unit {
  id        String   @id @default(cuid())
  name      String
  address   String
  phone     String?
  capacity  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students      Student[]
  classSessions ClassSession[]
  scopedUsers   User[]
}

model Package {
  id            String   @id @default(cuid())
  name          String
  classCount    Int
  priceCents    Int
  validityDays  Int      @default(0)
  active        Boolean  @default(true)
  effectiveFrom DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
