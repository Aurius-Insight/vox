{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm ci && npx --yes prisma generate && npm run build -w apps/web",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "functions": {
    "apps/api/api/index.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}
