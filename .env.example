NODE_ENV=development
# Fuso horario do processo Node. Em producao no Render, setar este TZ faz com
# que `new Date()` e logs saiam ja em BRT (sem depender de conversao na UI).
TZ=America/Sao_Paulo
APP_ORIGIN=http://localhost:5173
PORT=3333
DATABASE_URL=postgresql://vox:vox@localhost:5433/vox_mvp
REDIS_URL=redis://localhost:6380
SESSION_SECRET=change-this-session-secret-with-at-least-32-chars
WEBHOOK_SECRET=change-this-webhook-secret-with-at-least-24-chars
ADMIN_EMAIL=admin@voxrj.com
ADMIN_PASSWORD=change-this-admin-password
# Opcional. Sem ela, o envio do magic link via BotConversa fica como no-op
# (em dev, a resposta ainda devolve `devMagicLink` para facilitar o teste).
BOTCONVERSA_API_KEY=
