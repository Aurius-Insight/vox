NODE_ENV=development
# Fuso horario do processo Node. Em producao no Render, setar este TZ faz com
# que `new Date()` e logs saiam ja em BRT (sem depender de conversao na UI).
TZ=America/Sao_Paulo
APP_ORIGIN=http://localhost:5173
PORT=3333
DATABASE_URL=postgresql://vox:vox@localhost:5433/vox_mvp
# Em dev local, igual ao DATABASE_URL. Em prod com Supabase, DATABASE_URL e
# a URL do pooler (porta 6543, com `?pgbouncer=true&connection_limit=1`) e
# DIRECT_URL e a "Direct connection" (porta 5432) — usada por migrations.
DIRECT_URL=postgresql://vox:vox@localhost:5433/vox_mvp
REDIS_URL=redis://localhost:6380
# Em prod no Vercel, instalar "Upstash for Redis" via Marketplace injeta
# UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN automaticamente. Quando
# essas duas existem, o app usa Upstash via HTTP e ignora REDIS_URL.
# (Vercel KV original foi descontinuado em 2025; Upstash e a substituicao
# oficial via Marketplace.)
SESSION_SECRET=change-this-session-secret-with-at-least-32-chars
WEBHOOK_SECRET=change-this-webhook-secret-with-at-least-24-chars
# Opcional. Se ausente, hashes de CPF derivam de SESSION_SECRET (legado).
# Em deploys novos, defina um valor independente: se SESSION_SECRET
# vazar, os hashes de CPF ficam protegidos por outra chave. NAO setar
# retroativamente em prod existente — quebraria a dedup historica.
# Gerar com: openssl rand -hex 32
CPF_HASH_SALT=
ADMIN_EMAIL=admin@voxrj.com
ADMIN_PASSWORD=change-this-admin-password
# Tokens secretos dos links publicos de auto-cadastro (um por tipo). Gere com
# `node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"`.
# Sem eles, o endpoint /api/public/signup responde 404 (feature desligada).
PUBLIC_SIGNUP_TOKEN_MATRICULADO=
PUBLIC_SIGNUP_TOKEN_EXPERIMENTAL=
# Opcional. Sem ela, o envio do magic link via BotConversa fica como no-op
# (em dev, a resposta ainda devolve `devMagicLink` para facilitar o teste).
BOTCONVERSA_API_KEY=

# --- WhatsApp Cloud API (modo Coexistence/CoEx) — ver docs/PLANO_CHAT_COEX.md ---
# Todas opcionais: sem elas o cliente vira no-op e o webhook so responde a
# verificacao. Em dev/sandbox use o token temporario (24h) do painel da Meta.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
# Token de System User (longa duracao) em prod; temporario em dev.
WHATSAPP_ACCESS_TOKEN=
# App Secret do app Meta — valida a assinatura X-Hub-Signature-256 do webhook.
WHATSAPP_APP_SECRET=
# Token arbitrario que voce escolhe e repete no painel (GET de verificacao).
# Gerar com: openssl rand -hex 16
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v23.0
# Embedded Signup (conexao do numero real via CoEx). App ID e Config ID sao
# publicos; o App Secret (acima) faz a troca do code -> token no backend.
WHATSAPP_APP_ID=
WHATSAPP_ES_CONFIG_ID=
# featureType do FB.login para coexistencia (deixe o default salvo aqui).
WHATSAPP_ES_FEATURE_TYPE=whatsapp_business_app_onboarding
