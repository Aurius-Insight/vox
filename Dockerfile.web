# Build do frontend Vite. Nao precisa do Prisma client — apps/web nao importa
# @prisma/client (tipos sao duplicados via string literals em AuthProvider).
FROM node:22-alpine AS builder
WORKDIR /app

COPY package*.json ./
COPY apps/web/package.json ./apps/web/
# Instala so o workspace web pra economizar tempo de build e tamanho.
RUN npm ci -w apps/web --include-workspace-root

COPY apps/web ./apps/web
RUN npm run build -w apps/web

# Serve estatico via Nginx. Fallback de SPA em try_files.
FROM nginx:alpine
COPY --from=builder /app/apps/web/dist /usr/share/nginx/html
COPY nginx-web.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
